{
    "compilerOptions": {
        // Output
        "outDir": "bin",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "stripInternal": true,
        // Environment
        "target": "ES2022",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "moduleDetection": "force",
        "types": ["node"],
        // Type Checking
        "strict": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitReturns": true,
        "skipLibCheck": true
    },
    "files": [
        "apiKey.ts",
        "config/index.ts",
        "config/vars.ts",
        "domainAuthentication.ts",
        "domainAuthenticationValidation.ts",
        "eventWebhook.ts",
        "getTeammate.ts",
        "getTemplate.ts",
        "getTemplateVersion.ts",
        "getUnsubscribeGroup.ts",
        "index.ts",
        "linkBranding.ts",
        "parseWebhook.ts",
        "provider.ts",
        "ssoCertificate.ts",
        "ssoIntegration.ts",
        "subuser.ts",
        "teammate.ts",
        "template.ts",
        "templateVersion.ts",
        "types/index.ts",
        "types/input.ts",
        "types/output.ts",
        "unsubscribeGroup.ts",
        "utilities.ts",
        "webhookSecurityPolicy.ts"
    ]
}
